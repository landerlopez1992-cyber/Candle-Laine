# Copia este archivo a `.env.local` y rellena los valores (Settings → API en Supabase).

# URL del proyecto: https://<PROJECT_REF>.supabase.co
REACT_APP_SUPABASE_URL=https://jcddcuambbcwixpcvcuw.supabase.co

# Clave "anon public" (cliente web / app). Nunca subas `.env.local` a Git.
REACT_APP_SUPABASE_ANON_KEY=

# La clave "service_role" NO va aquí: solo en servidor, scripts o Edge Functions.

# Stripe Connect (OAuth): ID de cliente de la app en Stripe Dashboard → Connect (ca_…).
# Debe coincidir con el redirect URI: https://TU_DOMINIO/admin (y http://localhost:3000/admin en local).
REACT_APP_STRIPE_CONNECT_CLIENT_ID=
