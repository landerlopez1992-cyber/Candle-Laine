{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: start (beshop)",
      "type": "shell",
      "command": "npm run start",
      "options": {
        "cwd": "${workspaceFolder}/beshop",
        "env": {
          "BROWSER": "none"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting the development server",
          "endsPattern": "Compiled successfully!"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
