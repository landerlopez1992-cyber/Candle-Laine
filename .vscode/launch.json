{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "BeShop: npm start + Chrome (debug)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/beshop/src",
      "preLaunchTask": "npm: start (beshop)",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    },
    {
      "name": "BeShop: Chrome solo (servidor ya corriendo)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/beshop/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    }
  ]
}
